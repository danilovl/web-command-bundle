{
    "name": "danilovl/web-command-bundle",
    "description": "A Symfony bundle for running console commands via web interface",
    "type": "symfony-bundle",
    "keywords": ["php","symfony","bundle","web-command","rest-api","web-interface","console-command"],
    "license": "MIT",
    "support": {
        "source": "https://bitbucket.org/danilovl/web-command-bundle"
    },
    "authors": [
        {
            "name": "Vladimir Danilov"
        }
    ],
    "require": {
        "php": "^8.5",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/orm": "^3.6.2",
        "easycorp/easyadmin-bundle": "^4.27.6",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/messenger": "^8.0",
        "symfony/process": "^8.0",
        "symfony/twig-bundle": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.33",
        "phpstan/phpstan-symfony": "^2.0.9",
        "friendsofphp/php-cs-fixer": "^3.92.5"
    },
    "autoload": {
        "psr-4": {
            "Danilovl\\WebCommandBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Danilovl\\WebCommandBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "tests": "vendor/bin/phpunit tests",
        "phpstan": "phpstan analyse -c phpstan.neon src tests --no-progress",
        "phpstan-generate-baseline": "@php vendor/bin/phpstan analyse --level 9  --configuration phpstan.neon  src/ tests/ --generate-baseline",
        "cs-fixer": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "cs-fixer-check": "vendor/bin/php-cs-fixer fix --dry-run --allow-risky=yes"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    }
}
